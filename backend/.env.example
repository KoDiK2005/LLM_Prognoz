ENVIRONMENT=development
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/llm_prognoz
SECRET_KEY=change-me-to-a-random-string

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Self-hosted via Ollama — no key needed. On a GPU machine, bump the
# model up (e.g. llama3.1:8b or qwen2.5:14b) and pull it once:
# docker compose exec ollama ollama pull <model>
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:1b
