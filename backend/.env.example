ENVIRONMENT=development
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/llm_prognoz
REDIS_URL=redis://redis:6379/0
SECRET_KEY=change-me-to-a-random-string
# Comma-separated list of frontend origins allowed by CORS
CORS_ORIGINS=http://localhost:3000
MAX_UPLOAD_SIZE_MB=10

# Dataset file storage: "local" (default, disk under ./storage) or "s3"
# (real AWS S3, or any S3-compatible endpoint via S3_ENDPOINT_URL, e.g.
# self-hosted MinIO). AWS credentials come from the standard
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY env vars, not from here.
STORAGE_BACKEND=local
# S3_BUCKET=my-bucket
# S3_ENDPOINT_URL=http://minio:9000
# S3_REGION=us-east-1

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Self-hosted via Ollama — no key needed. On a GPU machine, bump the
# model up (e.g. llama3.1:8b or qwen2.5:14b) and pull it once:
# docker compose exec ollama ollama pull <model>
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:1b
